# Logto Management API credentials (1Password op:// references)
# Copy to .env and replace with your actual 1Password item references.
# Resolve with: op run --env-file .env -- python -m logto_management_skill ...

# Logto endpoint: full URL (https://auth.example.com) or tenant ID (xxxxxx)
LOGTO_ENDPOINT=op://your-vault/your-logto-item/endpoint

# M2M application credentials
LOGTO_APP_ID=op://your-vault/your-logto-item/app_id
LOGTO_APP_SECRET=op://your-vault/your-logto-item/app_secret

# Required only when using a custom domain (not *.logto.app)
# LOGTO_TENANT_ID=your-tenant-id